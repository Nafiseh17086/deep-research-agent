# ============================================
# LLM Provider Configuration
# ============================================
# Choose which LLM to use: "openai" or "anthropic"
LLM_PROVIDER=anthropic

# Model name (optional - uses sensible defaults if empty)
# OpenAI: gpt-4o, gpt-4o-mini, gpt-4-turbo
# Anthropic: claude-sonnet-4-5, claude-haiku-4-5, claude-opus-4-6
LLM_MODEL=

# ============================================
# API Keys
# ============================================
# Only fill in the ones you're using
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Tavily (required for web search) — get free key at https://tavily.com
TAVILY_API_KEY=

# ============================================
# Agent Behavior
# ============================================
# Max number of sub-questions the planner can generate
MAX_SUB_QUESTIONS=5

# Max search results per sub-question
MAX_SEARCH_RESULTS=5

# Temperature for LLM calls (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.2

# ============================================
# Optional: LangSmith Observability
# ============================================
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=deep-research-agent
